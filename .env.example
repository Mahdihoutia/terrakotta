# ─── Base de données Supabase ────────────────────────────────────
# Trouvable dans : Supabase Dashboard → Settings → Database → Connection string (URI)
# Format : postgresql://postgres.[REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=

# Alternative : connexion directe (pour les migrations Prisma)
# DIRECT_URL=postgresql://postgres.[REF]:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# ─── NextAuth ────────────────────────────────────────────────────
NEXTAUTH_SECRET=         # Générer : openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# ─── Email (formulaire contact) ──────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=contact@terrakotta.fr
