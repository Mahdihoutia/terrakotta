// Terrakotta — Schéma Prisma pour Supabase (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Utilisateur (mono-utilisateur) ─────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

// ─── Client ─────────────────────────────────────────────────────

model Client {
  id            String      @id @default(cuid())
  type          ClientType  @default(PARTICULIER)
  nom           String
  prenom        String?
  email         String?
  telephone     String?
  adresse       String?
  raisonSociale String?     @map("raison_sociale")
  siret         String?
  fonction      String?
  source        LeadSource  @default(SITE_WEB)
  statut        LeadStatus  @default(NOUVEAU)
  budgetEstime  Decimal?    @map("budget_estime")
  notes         String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @default(now()) @updatedAt @map("updated_at")
  projets       Projet[]
  devis         Devis[]
  evenements    Evenement[]

  @@map("clients")
}

// ─── Lead (prospects) ───────────────────────────────────────────

model Lead {
  id            String     @id @default(cuid())
  nom           String
  prenom        String?
  email         String
  telephone     String?
  raisonSociale String?    @map("raison_sociale")
  siret         String?
  fonction      String?
  type          ClientType @default(PARTICULIER)
  source        LeadSource @default(SITE_WEB)
  statut        LeadStatus @default(NOUVEAU)
  notes         String?
  budgetEstime  Decimal?   @map("budget_estime")
  dateCreation  DateTime   @default(now()) @map("date_creation")
  dateMiseAJour DateTime   @updatedAt @map("date_mise_a_jour")
  evenements    Evenement[]

  @@map("leads")
}

// ─── Projet ─────────────────────────────────────────────────────

model Projet {
  id             String         @id @default(cuid())
  titre          String
  description    String?
  statut         ProjetStatut   @default(EN_ATTENTE)
  typeClient     ClientType     @map("type_client")
  typeTravaux    String?        @map("type_travaux")
  adresseChantier String?       @map("adresse_chantier")
  budgetPrevu    Decimal?       @map("budget_prevu")
  budgetDepense  Decimal?       @default(0) @map("budget_depense")
  dateDebut      DateTime?      @map("date_debut")
  dateFin        DateTime?      @map("date_fin")
  clientId       String         @map("client_id")
  client         Client         @relation(fields: [clientId], references: [id])
  jalons         Jalon[]
  devis          Devis[]
  aides          Aide[]
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  @@map("projets")
}

// ─── Jalon (milestones) ─────────────────────────────────────────

model Jalon {
  id       String   @id @default(cuid())
  projetId String   @map("projet_id")
  titre    String
  echeance DateTime
  fait     Boolean  @default(false)
  projet   Projet   @relation(fields: [projetId], references: [id])

  @@map("jalons")
}

// ─── Devis ──────────────────────────────────────────────────────

model Devis {
  id         String      @id @default(cuid())
  numero     String      @unique
  objet      String?
  statut     DevisStatut @default(BROUILLON)
  montantHT  Decimal     @map("montant_ht")
  tauxTVA    Decimal     @default(20) @map("taux_tva")
  dateEmis   DateTime    @default(now()) @map("date_emis")
  dateValide DateTime?   @map("date_valide")
  clientId   String      @map("client_id")
  client     Client      @relation(fields: [clientId], references: [id])
  projetId   String?     @map("projet_id")
  projet     Projet?     @relation(fields: [projetId], references: [id])
  lignes     LigneDevis[]
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  @@map("devis")
}

// ─── Ligne de devis ────────────────────────────────────────────

model LigneDevis {
  id          String  @id @default(cuid())
  devisId     String  @map("devis_id")
  designation String
  unite       String  @default("U")
  quantite    Decimal @default(1)
  prixUnitHT  Decimal @map("prix_unit_ht")
  tauxTVA     Decimal @default(20) @map("taux_tva")
  ordre       Int     @default(0)
  devis       Devis   @relation(fields: [devisId], references: [id], onDelete: Cascade)

  @@map("lignes_devis")
}

// ─── Aide financière ───────────────────────────────────────────

model Aide {
  id            String     @id @default(cuid())
  projetId      String     @map("projet_id")
  type          AideType
  nom           String
  montant       Decimal?
  numeroDossier String?    @map("numero_dossier")
  statut        AideStatut @default(EN_ATTENTE)
  dateDepot     DateTime?  @map("date_depot")
  dateAccord    DateTime?  @map("date_accord")
  notes         String?
  projet        Projet     @relation(fields: [projetId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now()) @map("created_at")

  @@map("aides")
}

// ─── Événement (calendrier) ─────────────────────────────────────

model Evenement {
  id          String        @id @default(cuid())
  titre       String
  date        DateTime
  heureDebut  String        @map("heure_debut")
  heureFin    String        @map("heure_fin")
  type        EvenementType @default(RDV_CLIENT)
  lieu        String?
  commentaire String?
  clientId    String?       @map("client_id")
  client      Client?       @relation(fields: [clientId], references: [id])
  leadId      String?       @map("lead_id")
  lead        Lead?         @relation(fields: [leadId], references: [id])
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@map("evenements")
}

// ─── Enums ──────────────────────────────────────────────────────

enum ClientType {
  PARTICULIER
  PROFESSIONNEL
  COLLECTIVITE
}

enum LeadStatus {
  NOUVEAU
  CONTACTE
  QUALIFIE
  PROPOSITION
  GAGNE
  PERDU
}

enum LeadSource {
  SITE_WEB
  RECOMMANDATION
  RESEAU
  DEMARCHAGE
  AUTRE
}

enum ProjetStatut {
  EN_ATTENTE
  EN_COURS
  EN_PAUSE
  TERMINE
  ANNULE
}

enum DevisStatut {
  BROUILLON
  ENVOYE
  ACCEPTE
  REFUSE
}

enum EvenementType {
  VISITE
  RDV_CLIENT
  REUNION
  AUTRE
}

enum AideType {
  MAPRIMERENOVATION
  CEE
  ECO_PTZ
  AIDE_LOCALE
  COUP_DE_POUCE
  AUTRE
}

enum AideStatut {
  EN_ATTENTE
  DEPOSE
  EN_INSTRUCTION
  ACCORDE
  REFUSE
  VERSE
}
