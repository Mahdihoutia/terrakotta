// Kilowater — Schéma Prisma pour Supabase (PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Utilisateur (mono-utilisateur) ─────────────────────────────

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String?
  role      Role      @default(ADMIN)
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@map("users")
}

enum Role {
  ADMIN
  COLLABORATEUR
  LECTURE_SEULE
}

// ─── Client ─────────────────────────────────────────────────────

model Client {
  id            String      @id @default(cuid())
  type          ClientType  @default(PARTICULIER)
  nom           String
  prenom        String?
  email         String?
  telephone     String?
  adresse       String?
  ville         String?
  codePostal    String?     @map("code_postal")
  departement   String?
  raisonSociale String?     @map("raison_sociale")
  siret         String?
  fonction      String?
  source        LeadSource  @default(SITE_WEB)
  statut        LeadStatus  @default(NOUVEAU)
  budgetEstime  Decimal?    @map("budget_estime")
  notes         String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @default(now()) @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")
  projets       Projet[]
  devis         Devis[]
  factures      Facture[]
  evenements    Evenement[]

  @@index([deletedAt])
  @@map("clients")
}

// ─── Lead (prospects) ───────────────────────────────────────────

model Lead {
  id              String     @id @default(cuid())
  nom             String
  prenom          String?
  email           String
  telephone       String?
  raisonSociale   String?    @map("raison_sociale")
  siret           String?
  fonction        String?
  type            ClientType @default(PARTICULIER)
  source          LeadSource @default(SITE_WEB)
  statut          LeadStatus @default(NOUVEAU)
  notes           String?
  budgetEstime    Decimal?   @map("budget_estime")
  // Prospection fields
  score           Int?       @default(0) // 0-5 étoiles
  roleCible       String?    @map("role_cible") // Gestionnaire Technique, Maire, etc.
  adresse         String?
  ville           String?
  codePostal      String?    @map("code_postal")
  departement     String?
  surfaceBatiment Int?       @map("surface_batiment") // en m²
  sourceUrl       String?    @map("source_url") // URL de la source scraping
  dateCreation    DateTime   @default(now()) @map("date_creation")
  dateMiseAJour   DateTime   @updatedAt @map("date_mise_a_jour")
  deletedAt       DateTime?  @map("deleted_at")
  evenements      Evenement[]

  @@index([deletedAt])
  @@map("leads")
}

// ─── Projet ─────────────────────────────────────────────────────

model Projet {
  id             String         @id @default(cuid())
  titre          String
  description    String?
  statut         ProjetStatut   @default(EN_ATTENTE)
  typeClient     ClientType     @map("type_client")
  typeTravaux    String?        @map("type_travaux")
  adresseChantier String?       @map("adresse_chantier")
  budgetPrevu    Decimal?       @map("budget_prevu")
  budgetDepense  Decimal?       @default(0) @map("budget_depense")
  dateDebut      DateTime?      @map("date_debut")
  dateFin        DateTime?      @map("date_fin")
  clientId       String         @map("client_id")
  client         Client         @relation(fields: [clientId], references: [id])
  jalons         Jalon[]
  devis          Devis[]
  factures       Facture[]
  aides          Aide[]
  documents      Document[]
  batiments      Batiment[]
  systemes       Systeme[]
  variantes      Variante[]
  calculs        Calcul[]

  // Précision thermique (quick wins ingénieur)
  /// Nombre d'occupants — utilisé pour ECS (Nadeq) et apports internes.
  nbOccupants               Int?            @map("nb_occupants")
  /// Inertie thermique du bâti — impacte η_gn (utilisation apports).
  inertie                   InertieClasse?
  /// Programmation chauffage : intermittence nuit/WE active.
  intermittenceChauffage    Boolean         @default(false) @map("intermittence_chauffage")
  /// Perméabilité à l'air Q4Pa-surf (m³/h·m²).
  permeabiliteAir           Decimal?        @map("permeabilite_air")

  // Calibration facture (quick win #7)
  /// Conso chauffage annuelle réelle (kWh EF/an, moyenne 3 ans).
  consoFactureChauffage     Decimal?        @map("conso_facture_chauffage")
  /// Conso ECS annuelle réelle (kWh EF/an).
  consoFactureECS           Decimal?        @map("conso_facture_ecs")

  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")

  @@index([deletedAt])
  @@map("projets")
}

// ─── Variantes & Calculs immutables ─────────────────────────────

model Variante {
  id          String        @id @default(cuid())
  projetId    String        @map("projet_id")
  parentId    String?       @map("parent_id")
  type        VarianteType  @default(VARIANTE)
  nom         String
  description String?
  inputsJson  String        @map("inputs_json") // snapshot inputs (gestes, ressources foyer, options)
  projet      Projet        @relation(fields: [projetId], references: [id], onDelete: Cascade)
  parent      Variante?     @relation("VarianteFork", fields: [parentId], references: [id])
  forks       Variante[]    @relation("VarianteFork")
  calculs     Calcul[]
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  @@index([projetId])
  @@index([deletedAt])
  @@map("variantes")
}

model Calcul {
  id              String        @id @default(cuid())
  projetId        String        @map("projet_id")
  varianteId      String?       @map("variante_id")
  type            CalculType
  inputsJson      String        @map("inputs_json")  // snapshot complet inputs
  outputsJson     String        @map("outputs_json") // snapshot complet outputs
  moteurVersion   String        @map("moteur_version") // ex "thermal@2026-05-04"
  baremesVersion  String?       @map("baremes_version") // ex "2025-01-01" pour aides
  notes           String?
  projet          Projet        @relation(fields: [projetId], references: [id], onDelete: Cascade)
  variante        Variante?     @relation(fields: [varianteId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now()) @map("created_at")

  @@index([projetId])
  @@index([varianteId])
  @@index([type])
  @@index([createdAt])
  @@map("calculs")
}

// ─── Systèmes énergétiques ──────────────────────────────────────

model Systeme {
  id             String         @id @default(cuid())
  projetId       String         @map("projet_id")
  type           SystemeType
  vecteur        SystemeVecteur
  nom            String
  rendement      Decimal        @default(1)
  partCouverture Decimal        @default(1) @map("part_couverture")
  cop            Decimal?       // PAC : SCOP saisonnier
  /// Puissance crête kWc (PV uniquement).
  puissanceKwc   Decimal?       @map("puissance_kwc")
  /// Taux d'autoconsommation 0..1 (PV uniquement, défaut 0.4).
  tauxAutoconso  Decimal?       @map("taux_autoconso")
  notes          String?
  projet         Projet         @relation(fields: [projetId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")

  @@index([projetId])
  @@index([deletedAt])
  @@map("systemes")
}

// ─── Jalon (milestones) ─────────────────────────────────────────

model Jalon {
  id       String   @id @default(cuid())
  projetId String   @map("projet_id")
  titre    String
  echeance DateTime
  fait     Boolean  @default(false)
  projet   Projet   @relation(fields: [projetId], references: [id])

  @@map("jalons")
}

// ─── Devis ──────────────────────────────────────────────────────

model Devis {
  id         String      @id @default(cuid())
  numero     String      @unique
  objet      String?
  statut     DevisStatut @default(BROUILLON)
  montantHT  Decimal     @map("montant_ht")
  tauxTVA    Decimal     @default(20) @map("taux_tva")
  dateEmis   DateTime    @default(now()) @map("date_emis")
  dateValide DateTime?   @map("date_valide")
  clientId   String      @map("client_id")
  client     Client      @relation(fields: [clientId], references: [id])
  projetId   String?     @map("projet_id")
  projet     Projet?     @relation(fields: [projetId], references: [id])
  lignes     LigneDevis[]
  factureGeneree Facture? @relation("DevisToFacture")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  deletedAt  DateTime?   @map("deleted_at")

  @@index([deletedAt])
  @@map("devis")
}

// ─── Ligne de devis ────────────────────────────────────────────

model LigneDevis {
  id          String  @id @default(cuid())
  devisId     String  @map("devis_id")
  designation String
  unite       String  @default("U")
  quantite    Decimal @default(1)
  prixUnitHT  Decimal @map("prix_unit_ht")
  tauxTVA     Decimal @default(20) @map("taux_tva")
  ordre       Int     @default(0)
  devis       Devis   @relation(fields: [devisId], references: [id], onDelete: Cascade)

  @@map("lignes_devis")
}

// ─── Facture ────────────────────────────────────────────────────

model Facture {
  id             String         @id @default(cuid())
  numero         String         @unique
  objet          String?
  statut         FactureStatut  @default(BROUILLON)
  montantHT      Decimal        @map("montant_ht")
  tauxTVA        Decimal        @default(20) @map("taux_tva")
  dateEmis       DateTime       @default(now()) @map("date_emis")
  dateEcheance   DateTime?      @map("date_echeance")
  datePaiement   DateTime?      @map("date_paiement")
  modePaiement   String?        @map("mode_paiement")
  reference      String?
  clientId       String         @map("client_id")
  client         Client         @relation(fields: [clientId], references: [id])
  projetId       String?        @map("projet_id")
  projet         Projet?        @relation(fields: [projetId], references: [id])
  devisOrigineId String?        @unique @map("devis_origine_id")
  devisOrigine   Devis?         @relation("DevisToFacture", fields: [devisOrigineId], references: [id])
  lignes         LigneFacture[]
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  deletedAt      DateTime?      @map("deleted_at")

  @@index([deletedAt])
  @@index([clientId])
  @@map("factures")
}

model LigneFacture {
  id          String  @id @default(cuid())
  factureId   String  @map("facture_id")
  designation String
  unite       String  @default("U")
  quantite    Decimal @default(1)
  prixUnitHT  Decimal @map("prix_unit_ht")
  tauxTVA     Decimal @default(20) @map("taux_tva")
  ordre       Int     @default(0)
  facture     Facture @relation(fields: [factureId], references: [id], onDelete: Cascade)

  @@map("lignes_factures")
}

// ─── Poste catalogue (modèles de lignes de devis) ──────────────

model PosteCatalogue {
  id           String    @id @default(cuid())
  designation  String
  categorie    String?
  unite        String    @default("U")
  prixUnitHT   Decimal   @map("prix_unit_ht")
  tauxTVA      Decimal   @default(20) @map("taux_tva")
  description  String?
  ordre        Int       @default(0)
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@index([deletedAt])
  @@index([categorie])
  @@map("postes_catalogue")
}

// ─── Aide financière ───────────────────────────────────────────

model Aide {
  id            String     @id @default(cuid())
  projetId      String     @map("projet_id")
  type          AideType
  nom           String
  montant       Decimal?
  // CEE fields
  fiche         String?    // Ex: BAT-TH-134, BAR-TH-171
  kwhCumac      Decimal?   @map("kwh_cumac")
  prixUnitaire  Decimal?   @map("prix_unitaire") // €/MWh cumac
  numeroDossier String?    @map("numero_dossier")
  statut        AideStatut @default(EN_ATTENTE)
  dateDepot     DateTime?  @map("date_depot")
  dateAccord    DateTime?  @map("date_accord")
  notes         String?
  projet        Projet     @relation(fields: [projetId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @default(now()) @updatedAt @map("updated_at")
  deletedAt     DateTime?  @map("deleted_at")

  @@index([deletedAt])
  @@index([projetId])
  @@map("aides")
}

// ─── Événement (calendrier) ─────────────────────────────────────

model Evenement {
  id          String        @id @default(cuid())
  titre       String
  date        DateTime
  heureDebut  String        @map("heure_debut")
  heureFin    String        @map("heure_fin")
  type        EvenementType @default(RDV_CLIENT)
  lieu        String?
  commentaire String?
  clientId    String?       @map("client_id")
  client      Client?       @relation(fields: [clientId], references: [id])
  leadId      String?       @map("lead_id")
  lead        Lead?         @relation(fields: [leadId], references: [id])
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  @@index([deletedAt])
  @@map("evenements")
}

// ─── Document (rapports, notes de dimensionnement, audits) ─────

model Document {
  id            String         @id @default(cuid())
  titre         String
  reference     String         @unique
  type          DocumentType
  statut        DocumentStatut @default(BROUILLON)
  clientNom     String?        @map("client_nom")
  donnees       String?        // JSON stringified form values
  projetId      String?        @map("projet_id")
  projet        Projet?        @relation(fields: [projetId], references: [id], onDelete: SetNull)
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")

  @@index([deletedAt])
  @@map("documents")
}

// ─── AI Agent ──────────────────────────────────────────────────

model AIAgent {
  id            String       @id @default(cuid())
  nom           String
  description   String?
  type          AgentType
  statut        AgentStatut  @default(INACTIF)
  configuration Json         @default("{}")
  email         String?      // Email dédié pour l'agent communication
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  logs          AgentLog[]

  @@map("ai_agents")
}

model AgentLog {
  id        String        @id @default(cuid())
  agentId   String        @map("agent_id")
  agent     AIAgent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  action    String        // ex: "lead_created", "email_sent", "search_completed"
  details   Json          @default("{}")
  succes    Boolean       @default(true)
  createdAt DateTime      @default(now()) @map("created_at")

  @@map("agent_logs")
}

// ─── Bibliothèque matériaux & parois ───────────────────────────

model Materiau {
  id                String            @id @default(cuid())
  nom               String
  categorie         MateriauCategorie
  marque            String?
  reference         String?
  // Propriétés thermiques (NF EN ISO 6946)
  conductivite      Decimal           // λ en W/m·K
  masseVolumique    Decimal           @map("masse_volumique") // ρ en kg/m³
  capaciteThermique Decimal           @map("capacite_thermique") // c en J/kg·K
  resistanceVapeur  Decimal?          @map("resistance_vapeur") // µ
  // Optionnel : pour lames d'air, valeur de R fixe (m²·K/W)
  resistanceFixe    Decimal?          @map("resistance_fixe")
  // ACV
  carboneACV        Decimal?          @map("carbone_acv")
  carboneFinDeVie   Decimal?          @map("carbone_fin_de_vie")
  origineFdes       String?           @map("origine_fdes")
  source            String?
  notes             String?
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")
  deletedAt         DateTime?         @map("deleted_at")
  couches           ParoiCouche[]

  @@index([deletedAt])
  @@index([categorie])
  @@map("materiaux")
}

model Paroi {
  id                   String        @id @default(cuid())
  nom                  String
  type                 ParoiType
  description          String?
  uCache               Decimal?      @map("u_cache")
  rCache               Decimal?      @map("r_cache")
  masseSurfaciqueCache Decimal?      @map("masse_surfacique_cache")
  dephasageCache       Decimal?      @map("dephasage_cache")
  carboneCache         Decimal?      @map("carbone_cache")
  rsi                  Decimal       @default(0.13)
  rse                  Decimal       @default(0.04)
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")
  deletedAt            DateTime?     @map("deleted_at")
  couches              ParoiCouche[]
  zonesParois          ZoneParoi[]

  @@index([deletedAt])
  @@index([type])
  @@map("parois")
}

model ParoiCouche {
  id         String   @id @default(cuid())
  paroiId    String   @map("paroi_id")
  materiauId String   @map("materiau_id")
  ordre      Int
  epaisseur  Decimal
  paroi      Paroi    @relation(fields: [paroiId], references: [id], onDelete: Cascade)
  materiau   Materiau @relation(fields: [materiauId], references: [id])

  @@index([paroiId])
  @@map("paroi_couches")
}

// ─── Zoning thermique multi-zones (style Pleiades) ─────────────

model Batiment {
  id              String      @id @default(cuid())
  nom             String
  description     String?
  zoneClimatique  String      @map("zone_climatique")
  altitude        Decimal?
  orientation     String?
  projetId        String?     @map("projet_id")
  projet          Projet?     @relation(fields: [projetId], references: [id])
  auditDocumentId String?     @map("audit_document_id")
  zones           Zone[]
  pontsThermiques PontThermiqueLiaison[]
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")

  @@index([deletedAt])
  @@index([projetId])
  @@map("batiments")
}

model Zone {
  id                   String              @id @default(cuid())
  batimentId           String              @map("batiment_id")
  batiment             Batiment            @relation(fields: [batimentId], references: [id], onDelete: Cascade)
  nom                  String
  usage                ZoneUsage
  surface              Decimal
  hauteurSousPlafond   Decimal             @map("hauteur_sous_plafond")
  consigneChauffageOcc Decimal             @default(20) @map("consigne_chauffage_occ")
  consigneChauffageRed Decimal             @default(16) @map("consigne_chauffage_red")
  consigneClimOcc      Decimal             @default(26) @map("consigne_clim_occ")
  consigneClimRed      Decimal             @default(28) @map("consigne_clim_red")
  densiteOccupation    Decimal             @default(15) @map("densite_occupation")
  apportsParPersonne   Decimal             @default(80) @map("apports_par_personne")
  apportsEquipements   Decimal             @default(15) @map("apports_equipements")
  apportsEclairage     Decimal             @default(8)  @map("apports_eclairage")
  qVmcM3hM2            Decimal             @default(2.5) @map("qvmc_m3h_m2")
  efficaciteDoubleFlux Decimal             @default(0)   @map("efficacite_df")
  scenarioId           String?             @map("scenario_id")
  scenario             ScenarioOccupation? @relation(fields: [scenarioId], references: [id])
  parois               ZoneParoi[]
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")
  deletedAt            DateTime?           @map("deleted_at")

  @@index([deletedAt])
  @@index([batimentId])
  @@map("zones")
}

/// Liaisons pontuelles (Th-U fascicule 5/5) saisies au niveau bâtiment.
model PontThermiqueLiaison {
  id          String           @id @default(cuid())
  batimentId  String           @map("batiment_id")
  batiment    Batiment         @relation(fields: [batimentId], references: [id], onDelete: Cascade)
  typo        TypeLiaison
  isolation   TypeIsolation    @default(Aucune)
  longueur    Decimal
  /// Override ψ saisi manuellement (W/m·K). Sinon valeur biblio Th-U selon typo+isolation.
  psiOverride Decimal?         @map("psi_override")
  notes       String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")

  @@index([batimentId])
  @@index([deletedAt])
  @@map("ponts_thermiques_liaisons")
}

model ZoneParoi {
  id          String  @id @default(cuid())
  zoneId      String  @map("zone_id")
  paroiId     String  @map("paroi_id")
  zone        Zone    @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  paroi       Paroi   @relation(fields: [paroiId], references: [id])
  surface     Decimal
  orientation String?
  inclinaison Decimal? @default(90)
  cotePaire   Boolean? @default(false) @map("cote_paire")

  @@index([zoneId])
  @@map("zone_parois")
}

model ScenarioOccupation {
  id          String    @id @default(cuid())
  nom         String
  description String?
  patternJson String    @map("pattern_json")
  preset      Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  zones       Zone[]

  @@index([deletedAt])
  @@map("scenarios_occupation")
}

enum ZoneUsage {
  BUREAUX
  OPEN_SPACE
  CIRCULATION
  ARCHIVES
  SALLE_REUNION
  SALLE_SERVEUR
  COMMERCE
  RESTAURATION
  LOGEMENT
  HALL_ACCUEIL
  TECHNIQUE
  AUTRE
}

enum MateriauCategorie {
  STRUCTURE
  ISOLANT
  FINITION
  VITRAGE
  LAME_AIR
  MEMBRANE
  AUTRE
}

enum ParoiType {
  MUR_EXT
  MUR_INT
  TOITURE
  PLANCHER_BAS
  PLANCHER_INTER
  VITRAGE
  PORTE
}

// ─── Enums ──────────────────────────────────────────────────────

enum ClientType {
  PARTICULIER
  PROFESSIONNEL
  COLLECTIVITE
}

enum LeadStatus {
  NOUVEAU
  CONTACTE
  QUALIFIE
  PROPOSITION
  GAGNE
  PERDU
}

enum LeadSource {
  SITE_WEB
  RECOMMANDATION
  RESEAU
  DEMARCHAGE
  PAGES_JAUNES
  SOCIETE_COM
  WEB_SCRAPING
  SIRENE
  BODACC
  DPE_ADEME
  BOAMP
  PERMIS_CONSTRUIRE
  LINKEDIN
  INFOGREFFE
  PAPPERS
  CADASTRE_DVF
  FRANCE_TRAVAIL
  ANNONCES_LEGALES
  SIMULATEUR_AIDES
  AUTRE
}

enum ProjetStatut {
  EN_ATTENTE
